                finding: "Eng: Steep, rocky mountainous trails leading to physical distribution hubs completely isolate elderly residents and individuals with limited physical mobility, forcing them to rely on costly private transport or go without vital humanitarian aid.\nMya: မတ်စောက်ပြီး ကျောက်ဆောင်ထူထပ်သော တောင်ပေါ်လမ်းများကြောင့် သက်ကြီးရွယ်အိုများနှင့် မသန်စွမ်းသူများသည် အကူအညီဖြန့်ဝေရေးစခန်းသို့ မလာရောက်နိုင်ဘဲ အကူအညီမဲ့နေကြပါသည်။", 
                recom: "Eng: Transition to a direct home-delivery mechanism for isolated households. Create auxiliary, flat-terrain assembly nodes, and train youth volunteer circles to assist vulnerable persons during distributions.\nMya: မလာရောက်နိုင်သော အိမ်ထောင်စုများအတွက် အိမ်တိုင်ရာရောက်စနစ် (Home-Delivery) ဖြင့် ကူညီပါ။ လူငယ်စေတနာ့ဝန်ထမ်းများဖြင့် ကူညီသယ်ယူပေးရန် စီစဉ်ပါ။", 
                stateRegion: "Shan State (North)" 
            }
        ];

        let map;
        let markersGroup;

        // Tab switching logic
        function switchTab(tabId) {
            document.getElementById('content-dashboard').classList.add('hidden');
            document.getElementById('content-methodology').classList.add('hidden');
            document.getElementById('content-ethics').classList.add('hidden');

            document.getElementById('tab-dashboard').classList.remove('active-tab');
            document.getElementById('tab-methodology').classList.remove('active-tab');
            document.getElementById('tab-ethics').classList.remove('active-tab');

            document.getElementById(`content-${tabId}`).classList.remove('hidden');
            document.getElementById(`tab-${tabId}`).classList.add('active-tab');

            if (tabId === 'dashboard') {
                // Leaflet requires invalidating layout if unhidden
                setTimeout(() => { map.invalidateSize(); }, 200);
            }
        }

        // Toggle Accordion Rows
        function toggleAccordion(roleId) {
            const el = document.getElementById(`body-${roleId}`);
            const icon = document.getElementById(`icon-${roleId}`);
            if (el.classList.contains('hidden')) {
                el.classList.remove('hidden');
                icon.classList.add('rotate-180');
            } else {
                el.classList.add('hidden');
                icon.classList.remove('rotate-180');
            }
        }

        function showToast(message) {
            const toast = document.getElementById('toast-notif');
            const msgEl = document.getElementById('toast-message');
            msgEl.textContent = message;
            
            toast.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-2');
            toast.classList.add('opacity-100', 'translate-y-0');
            
            setTimeout(() => {
                toast.classList.add('opacity-0', 'pointer-events-none', 'translate-y-2');
                toast.classList.remove('opacity-100', 'translate-y-0');
            }, 3000);
        }

        // Filter geographical tables and maps
        function filterGeology(regionVal) {
            const rows = document.querySelectorAll('.geo-row');
            rows.forEach(row => {
                if (regionVal === 'all') {
                    row.classList.remove('hidden');
                } else if (row.getAttribute('data-state') === regionVal) {
                    row.classList.remove('hidden');
                } else {
                    row.classList.add('hidden');
                }
            });

            // Re-render Leaflet map markers to reflect active filter state
            markersGroup.clearLayers();
            townshipsData.forEach(t => {
                if (regionVal === 'all' || t.state === regionVal) {
                    addTownshipMarker(t);
                }
            });
            showToast(`Filtered context views by: ${regionVal}`);
        }

        // Focus and select location in the sidebar profile
        function selectTownshipOnUI(townshipName) {
            const t = townshipsData.find(item => item.name === townshipName);
            if (!t) return;

            const total = t.male + t.female;
            const malePct = ((t.male / total) * 100).toFixed(1);
            const femalePct = ((t.female / total) * 100).toFixed(1);

            document.getElementById('map-region-badge').textContent = t.stateRegion;
            document.getElementById('map-region-heading').textContent = `${t.name} Community`;
            document.getElementById('side-date').textContent = t.date;
            document.getElementById('side-method').textContent = `${t.method} Session`;
            document.getElementById('side-officer').textContent = t.officer;
            document.getElementById('side-gender').textContent = `Total: ${total} [M: ${t.male} (${malePct}%), F: ${t.female} (${femalePct}%)]`;
            
            // Clean HTML rendering for findings and recommendations with both languages
            document.getElementById('side-finding').innerHTML = t.finding.replace('\n', '<br><span class="text-xs text-slate-500 font-normal">');
            document.getElementById('side-recom').innerHTML = t.recom.replace('\n', '<br><span class="text-xs text-slate-500 font-normal">');

            const btn = document.getElementById('google-maps-btn');
            btn.href = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(t.name + ' ' + t.stateRegion + ' Myanmar')}`;
            btn.classList.remove('pointer-events-none', 'opacity-50');

            showToast(`Loaded ${t.name} Baseline Record`);
        }

        function addTownshipMarker(t) {
            const marker = L.circleMarker([t.lat, t.lng], {
                radius: 10,
                fillColor: t.state.includes('Shan') ? '#0284c7' : t.state === 'Kayah' ? '#0ea5e9' : t.state === 'Kayin' ? '#a855f7' : t.state === 'Rakhine' ? '#ef4444' : '#f59e0b',
                color: '#fff',
                weight: 2,
                opacity: 1,
                fillOpacity: 0.8
            }).addTo(markersGroup);

            marker.bindPopup(`
                <div class="text-xs space-y-1">
                    <strong class="text-brandSlate block font-bold">${t.name}</strong>
                    <span class="text-slate-500 block">Facilitator: ${t.officer}</span>
                    <span class="bg-sky-50 text-brandSky font-bold px-1.5 py-0.5 rounded block text-center mt-1">${t.date}</span>
                </div>
            `);

            marker.on('click', function() {
                selectTownshipOnUI(t.name);
            });
        }

        window.onload = function() {
            // Build Table Rows dynamically based on Chronological Sorting
            const tbody = document.getElementById('table-body');
            tbody.innerHTML = '';
            
            // Sort data chronologically prior to listing
            const sortedTownships = [...townshipsData].sort((a, b) => new Date(a.date) - new Date(b.date));

            sortedTownships.forEach(t => {
                const total = t.male + t.female;
                const mPct = ((t.male / total) * 100).toFixed(1);
                const fPct = ((t.female / total) * 100).toFixed(1);

                // Split strings for clean dual translation lines
                const formatBilingualCell = (val) => {
                    const lines = val.split('\n');
                    return `<div class="font-semibold text-slate-700">${lines[0]}</div><div class="text-[10px] text-slate-400 mt-1 burmese-font">${lines[1] || ''}</div>`;
                };

                const row = document.createElement('tr');
                row.className = "geo-row hover:bg-slate-50/50 transition-colors cursor-pointer";
                row.setAttribute('data-state', t.state);
                row.onclick = () => selectTownshipOnUI(t.name);

                row.innerHTML = `
                    <td class="p-4 pl-6 font-semibold text-brandSky">${t.stateRegion}</td>
                    <td class="p-4">
                        <div class="font-bold text-brandSlate">${t.name}</div>
                        <div class="text-[9px] text-brandSky font-bold tracking-tight uppercase mt-1 bg-sky-50 px-1.5 py-0.5 rounded border border-sky-100 inline-block">
                            <i class="fa-solid fa-map-location-dot mr-1"></i>Whole Township
                        </div>
                    </td>
                    <td class="p-4 font-medium text-slate-500">${t.date}</td>
                    <td class="p-4 font-semibold text-slate-600">${t.officer}</td>
                    <td class="p-4"><span class="px-2 py-1 rounded bg-slate-100 font-bold text-[10px] text-slate-600">${t.method}</span></td>
                    <td class="p-4 font-medium text-slate-600">Total: ${total}<br><span class="text-[10px] text-slate-400">M: ${t.male} (${mPct}%) | F: ${t.female} (${fPct}%)</span></td>
                    <td class="p-4 text-xs">${formatBilingualCell(t.access)}</td>
                    <td class="p-4 text-xs">${formatBilingualCell(t.safety)}</td>
                    <td class="p-4 text-xs">${formatBilingualCell(t.participation)}</td>
                    <td class="p-4 text-xs leading-relaxed">${formatBilingualCell(t.finding)}</td>
                    <td class="p-4 pr-6 text-xs leading-relaxed">${formatBilingualCell(t.recom)}</td>
                `;
                tbody.appendChild(row);
            });

            // Initialize OpenStreetMap Canvas centering over Central Myanmar coordinates
            map = L.map('map-canvas').setView([21.0, 96.5], 6);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            markersGroup = L.layerGroup().addTo(map);

            // Populate initially with all records
            townshipsData.forEach(t => {
                addTownshipMarker(t);
            });

            // Trigger initial focus on Demoso
            selectTownshipOnUI('Demoso');

            initializeChartsWithSafetyCheck();
        };

        function initializeChartsWithSafetyCheck() {
            if (typeof Chart === 'undefined') {
                console.warn("Chart.js is not loaded yet. Retrying in 100ms...");
                setTimeout(initializeChartsWithSafetyCheck, 100);
                return;
            }

            try {
                const ctxDistribution = document.getElementById('regionDistributionChart').getContext('2d');
                new Chart(ctxDistribution, {
                    type: 'bar',
                    data: {
                        labels: ['Shan State (North)', 'Shan State (South)', 'Shan State (East)', 'Kayah State', 'Kayin State', 'Rakhine State', 'Sagaing Region'],
                        datasets: [{
                            label: 'Completed Sessions',
                            data: [9, 4, 1, 2, 1, 1, 1],
                            backgroundColor: '#0284c7',
                            borderRadius: 8,
                            barThickness: 24
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true, ticks: { stepSize: 2 } } }
                    }
                });

                const ctxAccess = document.getElementById('accessBarriersChart').getContext('2d');
                new Chart(ctxAccess, {
                    type: 'doughnut',
                    data: {
                        labels: ['Physical Distance / Terrain', 'Checkpoint Delays / Shelling', 'Sanitation & Hygiene Concerns', 'Language & Info Access Gaps'],
                        datasets: [{
                            data: [42.5, 30, 15, 12.5],
                            backgroundColor: ['#0284c7', '#0ea5e9', '#ef4444', '#f59e0b'],
                            borderWidth: 0,
                            hoverOffset: 12
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, padding: 10 } } },
                        cutout: '70%'
                    }
                });
            } catch (err) {
                console.error("Error drawing Chart.js visualizations:", err);
            }
        }
    </script>
</body>
</html>
